//        ELSE pendingOrders(tt)(rr) := pendingOrders(tt)(rr) - am 
//        END        
//    END;
//    
////    4 - Análise 
//    
    me <-- getMenuRecipeExpectation(rr) =
        skip;
    
//    PRE rr: menu
//    THEN me:= expectedMenu(rr)
//    END;
